# Copy to `.env` in repo root (same directory as docker-compose.yml).
# Values below match `docker compose` service hostnames (db, redis).

ENVIRONMENT=local
DEBUG=false

DATABASE_URL=postgresql+asyncpg://audit:audit@db:5432/audit
DATABASE_URL_SYNC=postgresql+psycopg://audit:audit@db:5432/audit
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

JWT_SECRET_KEY=local-dev-secret-change-me-32chars-minimum!!
# Optional: separate key for OAuth token encryption at rest.
# If empty, backend falls back to JWT_SECRET_KEY.
OAUTH_TOKEN_ENCRYPTION_KEY=
JWT_ALGORITHM=HS256
# Access JWT lifetime (default 1440 = 24h). Refresh remains JWT_REFRESH_EXPIRE_DAYS.
JWT_ACCESS_EXPIRE_MINUTES=1440
JWT_REFRESH_EXPIRE_DAYS=14

CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Frontend (build-time / runtime in container)
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_API_V1_URL=http://localhost:8010/api/v1

# Yandex OAuth (Direct API account linking). Values must match the OAuth app in Yandex ID.
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
# Callback URL registered in Yandex OAuth app (backend route …/ad-accounts/oauth/callback).
YANDEX_OAUTH_REDIRECT_URI=
# Optional: long-lived token for local scripts only; web flow stores tokens per account in DB.
YANDEX_OAUTH_TOKEN=
# Where to redirect the browser after successful OAuth if the start URL did not pass ui_redirect.
# Example path deploy: https://<host>/YaDirect-analytics/settings — must match your Next basePath.
YANDEX_OAUTH_UI_DEFAULT_REDIRECT=

# Optional: Polza.ai
POLZA_AI_BASE_URL=https://polza.ai/api/v1
POLZA_AI_API_KEY=
AI_MODEL=gpt-4.1

# Audit policy defaults (override if needed)
MIN_CONVERSIONS_FOR_LEARNING=30
CHRONIC_BUDGET_LIMITED_DAYS_THRESHOLD=3
MAX_REDIRECT_HOPS=5
REQUIRED_UTM_PARAMS=utm_source,utm_medium,utm_campaign
SABOTAGE_REOPEN_WINDOW_DAYS=14

# Optional: absolute path to rule-catalog.json for admin UI "publish bundled" (otherwise image/repo default)
# BUNDLED_RULE_CATALOG_PATH=/srv/rule-catalog.json

WEEKLY_CRON_MINUTE=0
WEEKLY_CRON_HOUR=3
WEEKLY_CRON_DAY_OF_WEEK=1
