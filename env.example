# --- App ---
APP_NAME=yandex-direct-audit
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1

# Backend (inside Docker network use service names)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://audit:audit@db:5432/audit
DATABASE_URL_SYNC=postgresql+psycopg://audit:audit@db:5432/audit

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT (stage 2+)
JWT_SECRET_KEY=change-me-in-production-min-32-chars
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=14

# Yandex Direct API (stage 5+)
YANDEX_DIRECT_API_URL=https://api.direct.yandex.com/json/v5/
YANDEX_OAUTH_TOKEN=

# Polza.ai / OpenAI-compatible (stage 9+)
POLZA_AI_BASE_URL=https://polza.ai/api/v1
POLZA_AI_API_KEY=
AI_MODEL=gpt-4.1

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Policy defaults (stage 4+; overridable per tenant)
SABOTAGE_REOPEN_WINDOW_DAYS=14
MAX_REDIRECT_HOPS=5
MIN_CONVERSIONS_FOR_LEARNING=30
