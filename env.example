# --- App ---
APP_NAME=yadirect-analytics
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://audit:audit@db:5432/audit
DATABASE_URL_SYNC=postgresql+psycopg://audit:audit@db:5432/audit

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT
JWT_SECRET_KEY=change-me-in-production-min-32-chars-long!!
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=14

# Bootstrap admin (scripts/seed_admin.py)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMeNow123!

# Yandex Direct API (later stages)
YANDEX_DIRECT_API_URL=https://api.direct.yandex.com/json/v5/
YANDEX_OAUTH_TOKEN=

# Polza.ai (later stages)
POLZA_AI_BASE_URL=https://polza.ai/api/v1
POLZA_AI_API_KEY=
AI_MODEL=gpt-4.1

# Frontend — local Docker
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_API_V1_URL=http://localhost:8000/api/v1

# Frontend — production path on shared nginx (пример; URL в задаче был с опечаткой)
# NEXT_PUBLIC_BASE_PATH=/YaDirect-analytics
# NEXT_PUBLIC_API_V1_URL=https://atorichko.asur-adigital.ru/YaDirect-analytics/api/v1

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://atorichko.asur-adigital.ru

# Policy defaults (later)
SABOTAGE_REOPEN_WINDOW_DAYS=14
MAX_REDIRECT_HOPS=5
MIN_CONVERSIONS_FOR_LEARNING=30
