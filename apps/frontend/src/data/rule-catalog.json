{
  "catalog_version": "1.0.0",
  "platform": "yandex_direct",
  "included_levels": ["L1", "L2", "L3"],
  "severity_enum": {
    "warning": "Предупреждение",
    "high": "Высокий приоритет",
    "critical": "Критично"
  },
  "rules": [
    {
      "rule_code": "ACTIVE_CAMPAIGN_WITHOUT_ACTIVE_GROUPS",
      "name_ru": "Активная кампания без рабочих групп",
      "applies_to": ["all"],
      "severity": "high",
      "level": "L1",
      "entity_type": "campaign",
      "inputs": ["campaign.status", "groups[].status"],
      "detection_logic": "campaign.status=active AND count(groups where status=active)=0",
      "fail_condition": "active_campaign_without_active_groups",
      "evidence_fields": ["campaign_id", "campaign_name", "active_group_count"],
      "recommendation_ru": "Остановить кампанию или добавить рабочие группы."
    },
    {
      "rule_code": "ACTIVE_GROUP_WITHOUT_ACTIVE_ADS",
      "name_ru": "Активная группа без активных объявлений",
      "applies_to": ["all"],
      "severity": "critical",
      "level": "L1",
      "entity_type": "group",
      "inputs": ["group.status", "ads[].status", "ads[].serving_status"],
      "detection_logic": "group.status=active AND count(ads where serving_status=eligible)=0",
      "fail_condition": "active_group_without_servable_ads",
      "evidence_fields": ["campaign_id", "group_id", "active_ads_count", "rejected_ads_count"],
      "recommendation_ru": "Добавить или восстановить допущенные к показу объявления."
    },
    {
      "rule_code": "ACTIVE_GROUP_WITHOUT_TARGETING",
      "name_ru": "Активная группа без активных фраз или таргетингов",
      "applies_to": ["all"],
      "severity": "high",
      "level": "L1",
      "entity_type": "group",
      "inputs": ["group.status", "keywords[].status", "group.autotargeting", "group.audiences[]"],
      "detection_logic": "group.status=active AND count(active keywords)=0 AND autotargeting=disabled AND count(active audiences)=0",
      "fail_condition": "active_group_without_targeting_entities",
      "evidence_fields": ["campaign_id", "group_id", "active_keywords_count", "autotargeting_enabled", "active_audiences_count"],
      "recommendation_ru": "Добавить ключевые фразы, включить автотаргетинг или подключить аудитории."
    },
    {
      "rule_code": "GROUP_ALL_ADS_REJECTED",
      "name_ru": "Все объявления в группе отклонены модерацией",
      "applies_to": ["all"],
      "severity": "critical",
      "level": "L1",
      "entity_type": "group",
      "inputs": ["group.status", "ads[].moderation_status"],
      "detection_logic": "group.status=active AND count(ads)>0 AND count(ads where moderation_status=approved)=0",
      "fail_condition": "group_has_no_approved_ads",
      "evidence_fields": ["campaign_id", "group_id", "ads_count", "approved_ads_count"],
      "recommendation_ru": "Исправить отклоненные объявления или добавить новые."
    },
    {
      "rule_code": "ACTIVE_AD_REJECTED_OR_RESTRICTED",
      "name_ru": "Объявление отклонено или ограничено модерацией",
      "applies_to": ["all"],
      "severity": "high",
      "level": "L1",
      "entity_type": "ad",
      "inputs": ["ad.status", "ad.moderation_status", "ad.moderation_notes"],
      "detection_logic": "ad.status=active AND moderation_status in [rejected, limited]",
      "fail_condition": "active_ad_not_fully_approved",
      "evidence_fields": ["campaign_id", "group_id", "ad_id", "moderation_status", "moderation_notes"],
      "recommendation_ru": "Исправить объявление по замечаниям модерации."
    },
    {
      "rule_code": "DUPLICATE_KEYWORDS_IN_GROUP",
      "name_ru": "Дубликаты ключевых фраз в одной группе",
      "applies_to": ["all"],
      "severity": "warning",
      "level": "L1",
      "entity_type": "keyword",
      "inputs": ["group_id", "keywords[].text"],
      "detection_logic": "normalize(keyword.text) and find duplicates within same group",
      "fail_condition": "duplicate_normalized_keywords_in_group",
      "evidence_fields": ["campaign_id", "group_id", "keyword_ids", "normalized_keyword"],
      "recommendation_ru": "Удалить дублирующиеся ключевые фразы."
    },
    {
      "rule_code": "DUPLICATE_KEYWORDS_WITH_OVERLAP",
      "name_ru": "Дубликаты ключевых фраз в кампании или аккаунте с пересечением настроек",
      "applies_to": ["all"],
      "severity": "high",
      "level": "L1",
      "entity_type": "keyword",
      "inputs": ["keywords[].text", "campaign.geo", "campaign.schedule", "campaign.device_targeting"],
      "detection_logic": "normalize(keyword.text) and detect duplicates where geo/schedule/device overlap",
      "fail_condition": "duplicate_keywords_compete_with_each_other",
      "evidence_fields": ["keyword_ids", "campaign_ids", "group_ids", "normalized_keyword"],
      "recommendation_ru": "Развести фразы по структуре или ограничить пересечения настройками."
    },
    {
      "rule_code": "KEYWORD_CONFLICTS_WITH_GROUP_NEGATIVES",
      "name_ru": "Ключевая фраза пересечена минус-словом группы",
      "applies_to": ["all"],
      "severity": "critical",
      "level": "L1",
      "entity_type": "keyword",
      "inputs": ["keyword.text", "group.negative_keywords[]"],
      "detection_logic": "detect if any normalized negative term excludes the keyword intent or token set",
      "fail_condition": "keyword_blocked_by_group_negative",
      "evidence_fields": ["campaign_id", "group_id", "keyword_id", "keyword_text", "conflicting_negative"],
      "recommendation_ru": "Удалить конфликтующее минус-слово или изменить структуру фраз."
    },
    {
      "rule_code": "KEYWORD_CONFLICTS_WITH_CAMPAIGN_NEGATIVES",
      "name_ru": "Ключевая фраза пересечена минус-словом кампании",
      "applies_to": ["all"],
      "severity": "critical",
      "level": "L1",
      "entity_type": "keyword",
      "inputs": ["keyword.text", "campaign.negative_keywords[]"],
      "detection_logic": "detect if any normalized campaign negative excludes the keyword intent or token set",
      "fail_condition": "keyword_blocked_by_campaign_negative",
      "evidence_fields": ["campaign_id", "group_id", "keyword_id", "keyword_text", "conflicting_negative"],
      "recommendation_ru": "Удалить конфликтующее минус-слово кампании."
    },
    {
      "rule_code": "GROUP_KEYWORD_OVERLAP",
      "name_ru": "Пересечение групп по одинаковым или близким ключам",
      "applies_to": ["all"],
      "severity": "high",
      "level": "L1",
      "entity_type": "group",
      "inputs": ["groups[].keywords[].text", "campaign.geo", "campaign.schedule", "campaign.device_targeting"],
      "detection_logic": "compute normalized keyword overlap between groups where targeting settings overlap",
      "fail_condition": "groups_compete_on_same_or_nested_queries",
      "evidence_fields": ["campaign_id", "group_ids", "overlapping_keywords"],
      "recommendation_ru": "Разделить семантику и устранить внутреннюю конкуренцию."
    },
    {
      "rule_code": "MISSING_CROSS_NEGATIVES",
      "name_ru": "Отсутствие кросс-минусовки между группами",
      "applies_to": ["all"],
      "severity": "high",
      "level": "L1",
      "entity_type": "group",
      "inputs": ["groups[].keywords[].text", "groups[].negative_keywords[]"],
      "detection_logic": "for nested or overlapping groups check absence of disambiguating negatives",
      "fail_condition": "overlapping_groups_without_cross_negatives",
      "evidence_fields": ["campaign_id", "group_ids", "required_negative_terms"],
      "recommendation_ru": "Добавить кросс-минусовку между группами."
    },
    {
      "rule_code": "DUPLICATE_ADS",
      "name_ru": "Дубликаты объявлений",
      "applies_to": ["all"],
      "severity": "warning",
      "level": "L1",
      "entity_type": "ad",
      "inputs": ["ads[].title", "ads[].text", "ads[].url", "ads[].sitelinks[]"],
      "detection_logic": "normalize ad text fields and compare within group or campaign",
      "fail_condition": "duplicate_ads_detected",
      "evidence_fields": ["campaign_id", "group_id", "ad_ids", "normalized_signature"],
      "recommendation_ru": "Убрать дубли или протестировать разные варианты креативов."
    },
    {
      "rule_code": "DUPLICATE_SITELINKS",
      "name_ru": "Дубликаты быстрых ссылок",
      "applies_to": ["all"],
      "severity": "warning",
      "level": "L1",
      "entity_type": "ad_extension",
      "inputs": ["ad.sitelinks[].title", "ad.sitelinks[].url"],
      "detection_logic": "detect repeated normalized title or final URL within sitelinks of same ad",
      "fail_condition": "duplicate_sitelinks_in_ad",
      "evidence_fields": ["campaign_id", "group_id", "ad_id", "duplicate_sitelinks"],
      "recommendation_ru": "Сделать быстрые ссылки уникальными по тексту и URL."
    },
    {
      "rule_code": "MISSING_REQUIRED_EXTENSIONS",
      "name_ru": "Объявление без обязательных или ожидаемых дополнений",
      "applies_to": ["all"],
      "severity": "warning",
      "level": "L1",
      "entity_type": "ad",
      "inputs": ["ad.sitelinks[]", "ad.callouts[]", "ad.display_url", "ad.contact_info", "ad.image", "policy.required_extensions"],
      "detection_logic": "check missing extensions against service policy",
      "fail_condition": "required_extensions_missing",
      "evidence_fields": ["campaign_id", "group_id", "ad_id", "missing_extensions"],
      "recommendation_ru": "Заполнить рекомендуемые расширения."
    },
    {
      "rule_code": "EXPIRED_DATE_IN_AD_TEXT",
      "name_ru": "Неактуальная дата в тексте объявления",
      "applies_to": ["all", "real_estate"],
      "severity": "critical",
      "level": "L1",
      "entity_type": "ad",
      "inputs": ["ad.title", "ad.text", "current_date"],
      "detection_logic": "extract explicit dates and periods from ad text and compare with current_date",
      "fail_condition": "text_contains_expired_date_or_period",
      "evidence_fields": ["campaign_id", "group_id", "ad_id", "matched_date_text", "parsed_date"],
      "recommendation_ru": "Обновить текст объявления и удалить просроченные даты.",
      "industry_overrides": {
        "real_estate": {
          "additional_patterns": ["сдача в YYYY", "ключи в YYYY", "I кв. YYYY", "II кв. YYYY", "III кв. YYYY", "IV кв. YYYY"]
        }
      }
    },
    {
      "rule_code": "PAST_YEAR_IN_TEXT",
      "name_ru": "Упоминание прошлого года в тексте",
      "applies_to": ["all", "real_estate"],
      "severity": "warning",
      "level": "L1",
      "entity_type": "ad",
      "inputs": ["ad.title", "ad.text", "current_year"],
      "detection_logic": "extract year tokens from ad text and flag years less than current_year",
      "fail_condition": "text_contains_past_year",
      "evidence_fields": ["campaign_id", "group_id", "ad_id", "matched_years"],
      "recommendation_ru": "Проверить, не устарел ли оффер или ипотечная программа."
    },
    {
      "rule_code": "EXPIRED_DATE_IN_EXTENSIONS",
      "name_ru": "Неактуальная дата в быстрых ссылках или уточнениях",
      "applies_to": ["all", "real_estate"],
      "severity": "high",
      "level": "L1",
      "entity_type": "ad_extension",
      "inputs": ["ad.sitelinks[].title", "ad.sitelinks[].description", "ad.callouts[]", "current_date"],
      "detection_logic": "extract explicit dates and periods from extensions and compare with current_date",
      "fail_condition": "extensions_contain_expired_date_or_period",
      "evidence_fields": ["campaign_id", "group_id", "ad_id", "extension_type", "matched_date_text", "parsed_date"],
      "recommendation_ru": "Обновить тексты расширений."
    },
    {
      "rule_code": "UNRESOLVED_PLACEHOLDER_IN_TEXT",
      "name_ru": "Незаполненные шаблоны или плейсхолдеры в тексте",
      "applies_to": ["all", "real_estate"],
      "severity": "critical",
      "level": "L1",
      "entity_type": "ad",
      "inputs": ["ad.title", "ad.text"],
      "detection_logic": "detect placeholder patterns like {...}, {{...}}, %...%, [token], <token>",
      "fail_condition": "ad_text_contains_unresolved_placeholder",
      "evidence_fields": ["campaign_id", "group_id", "ad_id", "matched_placeholder"],
      "recommendation_ru": "Подставить фактическое значение вместо шаблона.",
      "industry_overrides": {
        "real_estate": {
          "additional_examples": ["[jk_name]", "{price}", "{mortgage_rate}", "{completion_date}"]
        }
      }
    },
    {
      "rule_code": "UNRESOLVED_PLACEHOLDER_IN_URL",
      "name_ru": "Незаполненные шаблоны или макросы в URL",
      "applies_to": ["all", "real_estate"],
      "severity": "critical",
      "level": "L3",
      "entity_type": "url",
      "inputs": ["ad.url", "ad.sitelinks[].url"],
      "detection_logic": "detect placeholder patterns in URLs like {...}, {{...}}, %...%, [token], <token>",
      "fail_condition": "url_contains_unresolved_placeholder",
      "evidence_fields": ["campaign_id", "group_id", "ad_id", "url_field", "matched_placeholder"],
      "recommendation_ru": "Исправить URL и удалить незаполненные шаблоны."
    },
    {
      "rule_code": "GEO_TEXT_TARGETING_MISMATCH",
      "name_ru": "Гео в тексте не совпадает с геотаргетингом",
      "applies_to": ["all", "real_estate"],
      "severity": "high",
      "level": "L1",
      "entity_type": "campaign",
      "inputs": ["campaign.geo", "ad.title", "ad.text", "geo_dictionary"],
      "detection_logic": "extract geographic entities from ad text and compare with campaign geo settings",
      "fail_condition": "ad_geo_entities_conflict_with_campaign_targeting",
      "evidence_fields": ["campaign_id", "group_id", "ad_id", "text_geo_entities", "campaign_geo"],
      "recommendation_ru": "Согласовать текст объявления с геотаргетингом."
    },
    {
      "rule_code": "CAMPAIGN_SELF_COMPETITION_BY_GEO_AND_SEMANTICS",
      "name_ru": "Активные кампании с пересекающимся гео и одинаковой семантикой",
      "applies_to": ["all"],
      "severity": "high",
      "level": "L1",
      "entity_type": "campaign",
      "inputs": ["campaigns[].geo", "campaigns[].schedule", "campaigns[].device_targeting", "campaigns[].keywords[].text"],
      "detection_logic": "detect campaigns with overlapping targeting and semantically duplicate keyword sets",
      "fail_condition": "campaigns_compete_with_each_other",
      "evidence_fields": ["campaign_ids", "overlapping_geo", "overlapping_keywords"],
      "recommendation_ru": "Развести кампании по регионам, времени, устройствам или семантике."
    },
    {
      "rule_code": "CONVERSION_STRATEGY_WITHOUT_METRIKA",
      "name_ru": "Стратегия по конверсиям без счетчика Метрики",
      "applies_to": ["all"],
      "severity": "critical",
      "level": "L2",
      "entity_type": "campaign",
      "inputs": ["campaign.strategy_type", "campaign.metrika_counter_id"],
      "detection_logic": "strategy_type in conversion_strategies AND metrika_counter_id is null",
      "fail_condition": "conversion_strategy_without_counter",
      "evidence_fields": ["campaign_id", "strategy_type", "metrika_counter_id"],
      "recommendation_ru": "Привязать счетчик Метрики к кампании."
    },
    {
      "rule_code": "CONVERSION_STRATEGY_WITHOUT_GOAL",
      "name_ru": "Стратегия по конверсиям без цели",
      "applies_to": ["all"],
      "severity": "critical",
      "level": "L2",
      "entity_type": "campaign",
      "inputs": ["campaign.strategy_type", "campaign.goal_ids[]"],
      "detection_logic": "strategy_type in conversion_strategies AND count(goal_ids)=0",
      "fail_condition": "conversion_strategy_without_goal",
      "evidence_fields": ["campaign_id", "strategy_type", "goal_ids"],
      "recommendation_ru": "Указать целевую цель или набор целей."
    },
    {
      "rule_code": "CONVERSION_STRATEGY_WITH_UNAVAILABLE_GOAL",
      "name_ru": "Используется удаленная или недоступная цель",
      "applies_to": ["all"],
      "severity": "critical",
      "level": "L2",
      "entity_type": "campaign",
      "inputs": ["campaign.goal_ids[]", "metrika.goals[].status", "metrika.goals[].access"],
      "detection_logic": "check each configured goal for existence and availability",
      "fail_condition": "configured_goal_unavailable",
      "evidence_fields": ["campaign_id", "goal_id", "goal_status", "goal_access"],
      "recommendation_ru": "Заменить недоступную цель на действующую."
    },
    {
      "rule_code": "CONVERSION_STRATEGY_WITHOUT_LEARNING_DATA",
      "name_ru": "Стратегия по конверсиям без статистики для обучения",
      "applies_to": ["all"],
      "severity": "high",
      "level": "L2",
      "entity_type": "campaign",
      "inputs": ["campaign.strategy_type", "stats.conversions", "analysis_period_days", "policy.min_conversions_for_learning"],
      "detection_logic": "strategy_type in conversion_strategies AND conversions over analysis period < policy.min_conversions_for_learning",
      "fail_condition": "insufficient_conversion_volume_for_learning",
      "evidence_fields": ["campaign_id", "strategy_type", "analysis_period_days", "conversions", "required_min_conversions"],
      "recommendation_ru": "Сменить стратегию или накопить больше конверсий."
    },
    {
      "rule_code": "CAMPAIGN_CHRONIC_BUDGET_LIMIT",
      "name_ru": "Кампания системно упирается в бюджет",
      "applies_to": ["all"],
      "severity": "high",
      "level": "L2",
      "entity_type": "campaign",
      "inputs": ["campaign.daily_budget", "stats.hourly_impressions", "stats.limited_by_budget_flags", "analysis_period_days"],
      "detection_logic": "detect repeated budget limitation events or early day traffic cutoff over analysis period",
      "fail_condition": "campaign_regularly_budget_limited",
      "evidence_fields": ["campaign_id", "analysis_period_days", "budget_limited_days", "avg_hour_of_budget_exhaustion"],
      "recommendation_ru": "Увеличить бюджет или перераспределить трафик."
    },
    {
      "rule_code": "INVALID_URL_SYNTAX",
      "name_ru": "Некорректный синтаксис URL",
      "applies_to": ["all"],
      "severity": "critical",
      "level": "L3",
      "entity_type": "url",
      "inputs": ["ad.url", "ad.sitelinks[].url"],
      "detection_logic": "validate URL format: scheme, host, encoding, spaces, illegal characters",
      "fail_condition": "url_not_parseable_or_invalid",
      "evidence_fields": ["campaign_id", "group_id", "ad_id", "url_field", "url_value", "validation_error"],
      "recommendation_ru": "Исправить формат URL."
    },
    {
      "rule_code": "FINAL_URL_HTTP_ERROR",
      "name_ru": "Ссылка ведет на 4xx или 5xx",
      "applies_to": ["all"],
      "severity": "critical",
      "level": "L3",
      "entity_type": "url",
      "inputs": ["ad.url", "http_check.status_code", "http_check.final_url"],
      "detection_logic": "perform HEAD or GET and flag final HTTP status in 4xx or 5xx",
      "fail_condition": "final_http_status_is_error",
      "evidence_fields": ["campaign_id", "group_id", "ad_id", "url_field", "checked_url", "final_url", "status_code"],
      "recommendation_ru": "Заменить или исправить ссылку."
    },
    {
      "rule_code": "FINAL_URL_DNS_TIMEOUT_CONNECTION_ERROR",
      "name_ru": "DNS, timeout или connection error",
      "applies_to": ["all"],
      "severity": "critical",
      "level": "L3",
      "entity_type": "url",
      "inputs": ["ad.url", "http_check.network_error", "http_check.dns_resolved", "http_check.timeout_ms"],
      "detection_logic": "flag DNS resolution failures, connection failures or timeout during URL check",
      "fail_condition": "url_unreachable_due_to_network_error",
      "evidence_fields": ["campaign_id", "group_id", "ad_id", "url_field", "checked_url", "network_error", "timeout_ms"],
      "recommendation_ru": "Проверить доступность домена и хостинга."
    },
    {
      "rule_code": "FINAL_URL_SSL_TLS_ERROR",
      "name_ru": "SSL/TLS ошибка",
      "applies_to": ["all"],
      "severity": "critical",
      "level": "L3",
      "entity_type": "url",
      "inputs": ["ad.url", "ssl_check.valid", "ssl_check.error", "ssl_check.expiry_date"],
      "detection_logic": "perform HTTPS handshake and certificate validation",
      "fail_condition": "ssl_or_tls_validation_failed",
      "evidence_fields": ["campaign_id", "group_id", "ad_id", "url_field", "checked_url", "ssl_error", "certificate_expiry_date"],
      "recommendation_ru": "Исправить сертификат или HTTPS-конфигурацию."
    },
    {
      "rule_code": "REDIRECT_LOOP",
      "name_ru": "Редирект-луп",
      "applies_to": ["all"],
      "severity": "critical",
      "level": "L3",
      "entity_type": "url",
      "inputs": ["ad.url", "http_check.redirect_chain[]"],
      "detection_logic": "follow redirects and detect repeated URLs or loop termination",
      "fail_condition": "redirect_loop_detected",
      "evidence_fields": ["campaign_id", "group_id", "ad_id", "url_field", "checked_url", "redirect_chain"],
      "recommendation_ru": "Исправить цепочку редиректов."
    },
    {
      "rule_code": "REDIRECT_CHAIN_TOO_LONG",
      "name_ru": "Слишком длинная цепочка редиректов",
      "applies_to": ["all", "real_estate"],
      "severity": "high",
      "level": "L3",
      "entity_type": "url",
      "inputs": ["ad.url", "http_check.redirect_chain[]", "policy.max_redirect_hops"],
      "detection_logic": "follow redirects and compare hop count with policy.max_redirect_hops",
      "fail_condition": "redirect_hops_exceed_limit",
      "evidence_fields": ["campaign_id", "group_id", "ad_id", "url_field", "checked_url", "redirect_hops", "redirect_chain"],
      "recommendation_ru": "Сократить число редиректов."
    },
    {
